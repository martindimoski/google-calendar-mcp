# Absolute path to a Google Service Account JSON key file.
# Generate via Google Cloud Console → IAM → Service Accounts → Keys.
# The service account must have Calendar API access, and any calendar you
# want to operate on must be shared with the service account email.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/absolute/path/to/service-account.json

# Optional. Port for the Express/MCP server. Defaults to 3000.
PORT=3000

# Optional. When truthy (default), every Google Calendar API response is
# pretty-printed to stdout. Set to "false" or "0" to log only the
# one-line request/response summaries.
LOG_GOOGLE_RESPONSES=true
